# Production Environment Variables
# Copy this to your hosting provider's environment variables

# PostgreSQL Database (Railway/Render/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/database

# Payload Secret - Generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-super-secret-key-here-min-32-chars

# Node Environment
NODE_ENV=production

# Frontend URL (for CORS/CSRF)
FRONTEND_URL=https://your-blog.vercel.app
